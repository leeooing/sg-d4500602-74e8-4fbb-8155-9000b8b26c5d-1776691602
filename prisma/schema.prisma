generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Table {
  id        String   @id @default(cuid())
  name      String
  capacity  Int
  status    String   @default("available") // available, occupied, reserved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tables")
}

model Booking {
  id           Int      @id @default(autoincrement())
  bookingCode  String   @unique
  name         String
  phone        String
  date         String
  time         String
  adults       Int
  children     Int      @default(0)
  service      String
  notes        String?
  adminNote    String?
  status       String   @default("pending") // pending, confirmed, rejected, expired
  paymentProof String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  items        BookingItem[]

  @@map("bookings")
}

model BookingItem {
  id         Int      @id @default(autoincrement())
  bookingId  Int
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  menuItemId Int
  name       String   // Store name for historical record
  price      String   // Store price at time of booking
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())

  @@map("booking_items")
}

model MenuItem {
  id           String   @id @default(cuid())
  name         String
  description  String
  price        String
  category     String
  image        String
  isAvailable  Boolean  @default(true)
  isBestSeller Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("menu_items")
  @@index([category])
}

model StaffRequest {
  id          String   @id @default(cuid())
  tableNumber String?
  requestType String   // call-staff, payment, support
  message     String   @default("")
  status      String   @default("pending") // pending, completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("staff_requests")
  @@index([status])
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}