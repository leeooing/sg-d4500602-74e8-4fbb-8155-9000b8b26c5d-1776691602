# Production Environment Variables
# Copy this to .env on your VPS and change values

# Database (PostgreSQL via Docker)
DATABASE_URL="postgresql://samcamping:CHANGE_THIS_PASSWORD@localhost:5432/samcamping_cafe"

# Admin Credentials (MUST CHANGE!)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_THIS_TO_STRONG_PASSWORD"

# Application
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Optional: If using external PostgreSQL
# DATABASE_URL="postgresql://user:password@your-db-host:5432/dbname"

# Security Notes:
# - Use strong passwords (12+ characters, mixed case, numbers, symbols)
# - Never commit .env file to git
# - Rotate passwords periodically
# - Backup your .env file securely